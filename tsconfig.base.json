{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@ac2/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@ac2/auth": [
        "packages/auth/src/index.ts"
      ]
    },
    "ignoreDeprecations": "6.0"
  }
}
